{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/pre-commit-docs.sh\"",
            "timeout": 180,
            "statusMessage": "docs-writer: updating README/CLAUDE.md/CHANGELOG before commit..."
          }
        ]
      }
    ]
  }
}
